{
  "name": "pi-squared",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm --filter pi-squared-agent build",
    "typecheck": "pnpm --filter pi-squared-agent typecheck",
    "typecheck:test": "pnpm --filter pi-squared-agent typecheck:test",
    "test": "pnpm --filter pi-squared-agent test",
    "test:watch": "pnpm --filter pi-squared-agent test:watch",
    "start": "pnpm --filter pi-squared-agent start",
    "dev": "pnpm --filter pi-squared-agent dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.60.0"
  }
}
