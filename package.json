{
  "name": "@chiwanpark/pi-squared",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "typecheck:test": "pnpm -r typecheck:test",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter @chiwanpark/pi-squared-agent test:watch",
    "start": "pnpm --filter @chiwanpark/pi-squared-agent start",
    "dev": "pnpm --filter @chiwanpark/pi-squared-agent dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.60.0"
  },
  "dependencies": {
    "@chiwanpark/pi-squared-agent": "link:agent"
  }
}
