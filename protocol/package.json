{
  "name": "@chiwanpark/pi-squared-protocol",
  "version": "0.1.0",
  "description": "Shared protocol types and validators for pi-squared packages.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiwanpark/pi-squared.git",
    "directory": "protocol"
  },
  "bugs": {
    "url": "https://github.com/chiwanpark/pi-squared/issues"
  },
  "homepage": "https://github.com/chiwanpark/pi-squared#readme",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "lint": "pnpm --workspace-root lint",
    "lint:fix": "pnpm --workspace-root lint:fix",
    "format": "pnpm --workspace-root format",
    "format:check": "pnpm --workspace-root format:check"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
