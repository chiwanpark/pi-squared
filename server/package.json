{
  "name": "@chiwanpark/pi-squared-server",
  "version": "0.2.0",
  "description": "Server for collecting pi-squared agent session messages.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiwanpark/pi-squared.git",
    "directory": "server"
  },
  "bugs": {
    "url": "https://github.com/chiwanpark/pi-squared/issues"
  },
  "homepage": "https://github.com/chiwanpark/pi-squared#readme",
  "bin": {
    "pi2-server": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --filter @chiwanpark/pi-squared-protocol build && tsc -p tsconfig.json && chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "pnpm --filter @chiwanpark/pi-squared-protocol build && vitest run --passWithNoTests",
    "test:watch": "pnpm --filter @chiwanpark/pi-squared-protocol build && vitest --passWithNoTests",
    "start": "pnpm build && node dist/cli.js",
    "dev": "pnpm --filter @chiwanpark/pi-squared-protocol build && tsx src/cli.ts",
    "lint": "pnpm --workspace-root lint",
    "lint:fix": "pnpm --workspace-root lint:fix",
    "format": "pnpm --workspace-root format",
    "format:check": "pnpm --workspace-root format:check"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@chiwanpark/pi-squared-protocol": "workspace:*",
    "ws": "^8.21.0"
  }
}
